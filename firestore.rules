rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidBin(data) {
      return data.keys().hasAll(['id', 'lat', 'lng', 'fillLevel', 'zone', 'lastUpdated', 'isPriority', 'isManualPriority', 'baseFillRate', 'type']) &&
        data.id is string && data.id.size() <= 64 &&
        data.lat is number && data.lng is number &&
        data.fillLevel is number && data.fillLevel >= 0 && data.fillLevel <= 100 &&
        data.zone is string && data.zone.size() <= 100 &&
        data.lastUpdated is string && data.lastUpdated.size() <= 64 &&
        data.isPriority is bool && data.isManualPriority is bool &&
        data.baseFillRate is number &&
        data.type is string && (data.type == 'commercial' || data.type == 'residential' || data.type == 'industrial');
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && request.auth.token.email_verified == true;
    }

    match /bins/{binId} {
      allow read: if true; // Public route planning / dashboard
      allow create: if true && isValidBin(incoming()) && incoming().id == binId;
      allow update: if true && isValidBin(incoming()) && incoming().diff(existing()).affectedKeys().hasAny(['fillLevel', 'lastUpdated', 'isPriority', 'isManualPriority', 'baseFillRate', 'type', 'lat', 'lng', 'zone']);
      allow delete: if true;
    }

    function isValidReport(data, isUpdate) {
      return (isUpdate || data.keys().hasAll(['id', 'binId', 'userId', 'timestamp'])) &&
        (!('id' in data) || data.id is string) &&
        (!('binId' in data) || data.binId is string) &&
        (!('userId' in data) || data.userId is string) &&
        (!('timestamp' in data) || data.timestamp is string) &&
        (!('trustScore' in data) || data.trustScore is number) &&
        (!('markedFake' in data) || data.markedFake is bool) &&
        (!('description' in data) || data.description is string) &&
        (!('userEmail' in data) || data.userEmail is string) &&
        (!('lat' in data) || data.lat is number) &&
        (!('lng' in data) || data.lng is number) &&
        (!('aiTags' in data) || data.aiTags is list);
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if isValidReport(incoming(), false) && incoming().id == reportId;
      allow update: if (isSignedIn() || true) && isValidReport(incoming(), true);
    }

    function isValidCitizen(data, isUpdate) {
      return (isUpdate || data.keys().hasAll(['userId', 'reliabilityScore', 'fakeReports', 'blocked'])) &&
        (!('userId' in data) || data.userId is string) &&
        (!('reliabilityScore' in data) || data.reliabilityScore is number) &&
        (!('fakeReports' in data) || data.fakeReports is number) &&
        (!('blocked' in data) || data.blocked is bool);
    }

    match /citizens/{citizenId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
